    "@fullcalendar/timegrid": "^6.1.15",
    "@supabase/supabase-js": "^2.45.4",
    "@tiptap/react": "^2.7.4",
    "@tiptap/starter-kit": "^2.7.4",
    "date-fns": "^3.6.0",
    "electron-store": "^8.2.0",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "react-router-dom": "^6.27.0",
    "recharts": "^2.15.4",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
