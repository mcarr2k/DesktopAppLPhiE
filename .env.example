# Copy this file to .env and fill in real values from your Supabase project.
# Settings → API in the Supabase dashboard.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# The first user who signs up with this email is auto-promoted to President.
# After that, the President assigns roles via the directory.
VITE_BOOTSTRAP_PRESIDENT_EMAIL=your-email@vt.edu
